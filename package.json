{
  "name": "zopilot",
  "type": "module",
  "version": "0.6.4",
  "description": "Bring AI into Zotero, as your research copilot.",
  "config": {
    "addonName": "Zopilot",
    "addonID": "zopilot@qyangcv.github.io",
    "addonRef": "zopilot",
    "addonInstance": "Zopilot",
    "prefsPrefix": "extensions.zotero.zopilot"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qyangcv/zopilot.git"
  },
  "author": "qyang",
  "bugs": {
    "url": "https://github.com/qyangcv/zopilot/issues"
  },
  "homepage": "https://github.com/qyangcv/zopilot#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "build:pdf-helper": "node scripts/build-pdf-helper-current.mjs",
    "build:pdf-helper:macos-arm64": "python3 scripts/build-pdf-helper.py --platform macos-arm64",
    "build:pdf-helper:macos-x64": "python3 scripts/build-pdf-helper.py --platform macos-x64",
    "build:pdf-helper:windows-x64": "python scripts/build-pdf-helper.py --platform windows-x64",
    "build:pdf-helper:manifest": "python3 scripts/merge-pdf-helper-manifest.py",
    "release:pdf-helper": "gh workflow run pdf-helper.yml --ref dist",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "test:unit": "node --import ./test/register-ts-loader.mjs ./node_modules/mocha/bin/mocha \"test/unit/**/*.test.ts\" \"test/unit/**/*.test.tsx\"",
    "test:l10n": "node --import ./test/register-ts-loader.mjs ./node_modules/mocha/bin/mocha test/unit/preferences/localizationResources.test.ts test/unit/preferences/providerMessages.test.ts",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.56",
    "@mdit/plugin-footnote": "^0.23.2",
    "@mdit/plugin-tasklist": "^0.23.2",
    "@mdit/plugin-tex": "^0.24.2",
    "@openai/agents": "^0.12.0",
    "@openai/agents-extensions": "^0.12.0",
    "ai": "^6.0.219",
    "flexsearch": "^0.8.212",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "markdown-it": "^14.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-html": "^2.17.5",
    "shiki": "^4.2.0",
    "zod": "^4.4.3",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
